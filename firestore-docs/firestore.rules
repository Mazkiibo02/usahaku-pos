rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // HELPER FUNCTIONS
    // =========================================================

    // Cek apakah user sudah login
    function isAuthenticated() {
      return request.auth != null;
    }

    // Ambil tenantId dari Custom Claims (0 read cost)
    function myTenantId() {
      return request.auth.token.tenantId;
    }

    // Ambil role dari Custom Claims (0 read cost)
    function myRole() {
      return request.auth.token.role;
    }

    // Ambil outletId dari Custom Claims (0 read cost)
    function myOutletId() {
      return request.auth.token.outletId;
    }

    // Cek apakah user adalah owner
    function isOwner() {
      return isAuthenticated() && myRole() == 'owner';
    }

    // Cek apakah user adalah kasir
    function isCashier() {
      return isAuthenticated() && myRole() == 'cashier';
    }

    // Cek apakah user adalah owner ATAU kasir (authenticated tenant member)
    function isTenantMember() {
      return isAuthenticated() && (myRole() == 'owner' || myRole() == 'cashier');
    }

    // Cek apakah resource milik tenant yang sama
    function isSameTenant() {
      return resource.data.tenantId == myTenantId();
    }

    // Cek apakah data yang akan ditulis/dibaca milik tenant yang sama
    function isWritingToMyTenant() {
      return request.resource.data.tenantId == myTenantId();
    }

    // Pastikan tenant aktif (tidak expired/suspended) — baca dari tenants doc
    // Digunakan untuk operasi kritis seperti buat transaksi
    function isTenantActive() {
      let tenant = get(/databases/$(database)/documents/tenants/$(myTenantId()));
      return tenant.data.subscriptionStatus == 'trial'
          || tenant.data.subscriptionStatus == 'active';
    }

    // Cek apakah owner masih diperbolehkan menambah outlet berdasarkan plan (maxOutlets)
    function canCreateOutlet() {
      let tenant = get(/databases/$(database)/documents/tenants/$(myTenantId())).data;
      let count = ('outletsCount' in tenant) ? tenant.outletsCount : 0;
      let max = ('maxOutlets' in tenant) ? tenant.maxOutlets : 2;
      return count < max;
    }


    // =========================================================
    // COLLECTION: tenants/{tenantId}
    // =========================================================
    // Owner & Kasir (Tenant Member): read
    // Owner: update (edit profil bisnis, receiptFooter, dll)
    // Create/delete: hanya via Cloud Function (Admin SDK), bukan dari client
    // =========================================================

    match /tenants/{tenantId} {
      allow read: if isTenantMember()
                  && request.auth.token.tenantId == tenantId;

      allow update: if isOwner()
                    && request.auth.token.tenantId == tenantId
                    // Proteksi field kritis — tidak boleh diubah dari client
                    && !request.resource.data.diff(resource.data).affectedKeys()
                        .hasAny([
                          'tenantId',
                          'ownerUid',
                          'subscriptionStatus',
                          'subscriptionPlan',
                          'trialEndsAt',
                          'subscriptionEndsAt',
                          'createdAt',
                          'maxOutlets'
                        ]);

      allow create, delete: if false; // Hanya Cloud Function
    }

    // =========================================================
    // COLLECTION: tenants/{tenantId}/shifts/{shiftId}
    // =========================================================
    // Owner & Kasir (Tenant Member): read, create, update
    // Membuka shift baru (create) dan menutup/mencatat modal (update)
    // Dibatasi ketat berdasarkan tenantId dari Custom Claims user
    // =========================================================

    match /tenants/{tenantId}/shifts/{shiftId} {
      allow read, create: if isTenantMember()
                          && request.auth.token.tenantId == tenantId;

      allow update: if request.auth.token.tenantId == tenantId
                    && (
                      isOwner()
                      || (
                        isCashier()
                        && resource.data.status == 'OPEN'
                        && request.resource.data.status == 'CLOSED'
                      )
                    );
    }


    // =========================================================
    // COLLECTION: users/{uid}
    // =========================================================
    // Owner: read semua user dalam tenantnya, update profil kasir (isActive, name)
    // Kasir: read dokumen dirinya sendiri saja
    // Create/delete: hanya via Cloud Function (Admin SDK)
    // =========================================================

    match /users/{uid} {
      allow read: if isAuthenticated()
                  && (
                    // Owner bisa baca semua user di tenantnya
                    (isOwner() && resource.data.tenantId == myTenantId())
                    ||
                    // User can read their own document (e.g., during login check)
                    (request.auth.uid == uid)
                  );

      allow update: if isAuthenticated()
                    && (
                      // Owner can update staff/cashier fields (name, phone, isActive, outletId, updatedAt)
                      (isOwner() && resource.data.tenantId == myTenantId()
                       && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['name', 'phone', 'isActive', 'lastLoginAt', 'outletId', 'updatedAt']))
                      ||
                      // Users can update their own profile document (e.g., editing display name or profile picture)
                      (request.auth.uid == uid)
                    )
                    // CRITICAL PROTECTION: Role and Tenant Immutability Guard
                    && request.resource.data.role == resource.data.role
                    && request.resource.data.tenantId == resource.data.tenantId;

      allow create, delete: if false; // Hanya Cloud Function
    }


    // =========================================================
    // COLLECTION: outlets/{outletId}
    // =========================================================
    // Owner: full CRUD semua outlet miliknya
    // Kasir: read outlet yang dia ditugaskan saja
    // =========================================================

    match /outlets/{outletId} {
      allow read: if isTenantMember()
                  && isSameTenant();

      allow create: if isOwner()
                    && isWritingToMyTenant()
                    // Proteksi: tenantId tidak boleh berbeda dari claims
                    && request.resource.data.tenantId == myTenantId()
                    && canCreateOutlet();

      allow update: if isOwner()
                    && isSameTenant()
                    // Proteksi: tenantId tidak boleh diubah
                    && request.resource.data.tenantId == resource.data.tenantId;

      allow delete: if isOwner()
                    && isSameTenant();
    }


    // =========================================================
    // COLLECTION: products/{productId}
    // =========================================================
    // Owner: full CRUD
    // Kasir: read only (untuk search di POS), tidak bisa write apapun
    // Stok decrement dilakukan via batch write transaksi (bukan direct update di sini)
    // =========================================================

    match /products/{productId} {
      allow read: if isTenantMember() && isSameTenant();
      allow create, delete: if isOwner() && isWritingToMyTenant();
      allow update: if isTenantMember() && isWritingToMyTenant() && (
        isOwner() || 
        (
          isCashier() && 
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['stock', 'updatedAt']) &&
          request.resource.data.stock < resource.data.stock
        )
      );
    }


    // =========================================================
    // COLLECTION: transactions/{transactionId}
    // =========================================================
    // Owner: create + read semua transaksi di tenantnya
    // Kasir: create + read transaksi di outlet yang dia tugaskan saja
    // Update & Delete: DIBLOKIR TOTAL untuk semua role (no refund/retur)
    // =========================================================

    match /transactions/{transactionId} {
      allow read: if isTenantMember()
                  && isSameTenant();

      allow create: if isTenantMember()
                    && isWritingToMyTenant();

      allow update: if isTenantMember()
                    && isSameTenant()
                    && isWritingToMyTenant();
    }


    // =========================================================
    // COLLECTION: stockMutations/{mutationId}
    // =========================================================
    // Owner & Kasir: read
    // Cashier & Owner: create (if authenticated and matching claims)
    // Update & Delete: blocked
    // =========================================================

    match /stockMutations/{mutationId} {
      allow read: if (isOwner() && resource.data.tenantId == myTenantId()) || (isCashier() && resource.data.tenantId == myTenantId() && resource.data.outletId == myOutletId());
      allow create: if isTenantMember() && isWritingToMyTenant() && (
        isOwner() ||
        (isCashier() && request.resource.data.tenantId == myTenantId() && request.resource.data.outletId == myOutletId())
      );
      allow update, delete: if false;
    }


    // =========================================================
    // COLLECTION: dashboards/{docId} (and stats/{tenantId}/{document=**})
    // =========================================================
    // Owner: read only (dokumen tenantnya)
    // Kasir: tidak bisa akses sama sekali
    // Write: hanya Cloud Function (Admin SDK)
    // =========================================================

    match /dashboards/{docId} {
      allow read: if isOwner() && (docId == myTenantId() || (resource != null && resource.data.tenantId == myTenantId()));

      allow write: if false; // Hanya Cloud Function
    }

    match /stats/{tenantId}/{document=**} {
      allow read: if isOwner() && tenantId == myTenantId();
      allow write: if false;
    }


    // =========================================================
    // COLLECTION: invoices/{invoiceId}
    // =========================================================
    // Owner: read, create, update (untuk cek status pembayaran & perpanjang langganan)
    // Kasir: read (outlet-isolated), create (outlet-isolated), no update/delete
    // =========================================================

    match /invoices/{invoiceId} {
      allow read: if isTenantMember()
                  && isSameTenant();

      allow create: if isTenantMember()
                    && isWritingToMyTenant();

      allow update: if isOwner()
                    && isSameTenant()
                    && isWritingToMyTenant();

      allow delete: if isOwner()
                    && isSameTenant();
    }



    // =========================================================
    // COLLECTION: barcodeIndex/{barcode}
    // =========================================================
    // Flat lookup index untuk barcode scan (2 reads: index + product doc)
    // Owner & Kasir: read only
    // Write: hanya saat create/update produk (via Cloud Function atau owner)
    // =========================================================

    match /barcodeIndex/{barcode} {
      allow read: if isTenantMember()
                  && resource.data.tenantId == myTenantId();

      allow write: if isOwner()
                   && (
                     !exists(/databases/$(database)/documents/barcodeIndex/$(barcode))
                     || resource.data.tenantId == myTenantId()
                   );
    }


    // =========================================================
    // COLLECTION: audit_logs/{logId}
    // =========================================================
    // Write-once, immutable logs for critical actions.
    // Read: Only Owner of the same tenant can read.
    // Create: Any authenticated user of the same tenant can create.
    // Update/Delete: Blocked completely.
    // =========================================================

    match /audit_logs/{logId} {
      allow create: if request.auth != null
                    && request.resource.data.tenantId == request.auth.token.tenantId;

      allow read: if request.auth != null
                  && request.auth.token.role == 'owner'
                  && resource.data.tenantId == request.auth.token.tenantId;

      allow update, delete: if false;
    }


    // =========================================================
    // DEFAULT: Tolak semua akses yang tidak didefinisikan
    // =========================================================

    match /{document=**} {
      allow read, write: if false;
    }

  }
}

